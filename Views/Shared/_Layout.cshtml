<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Labilletterie</title>

    <!-- Nos fichiers CSS -->
    <link rel="stylesheet" href="~/css/variables.css" />
    <link rel="stylesheet" href="~/css/base.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <a href="/" class="navbar__logo">La<span>billetterie</span></a>

        <!-- Bouton burger mobile -->
        <button class="navbar__burger" id="burger" aria-label="Menu">
            <span></span>
            <span></span>
            <span></span>
        </button>

        <!-- Liens de navigation -->
        <ul class="navbar__liens" id="menu">
            <li><a href="/Evenements">Événements</a></li>

            @* Si l'utilisateur est connecté *@
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <li><a href="/Compte/MonEspace">Mon espace</a></li>
                <li><a href="/Compte/Deconnexion">Déconnexion</a></li>
            }
            else
            {
                <li><a href="/Compte/Connexion">Connexion</a></li>
                <li><a href="/Compte/Inscription" class="btn-secondaire">S'inscrire</a></li>
            }
        </ul>
    </nav>

    <!-- CONTENU PRINCIPAL -->
    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="footer">
        <ul class="footer__liens">
            <li><a href="/mentions-legales">Mentions légales</a></li>
            <li><a href="/cgv">CGV</a></li>
            <li><a href="/cgu">CGU</a></li>
            <li><a href="/rgpd">RGPD</a></li>
        </ul>
        <p>© @DateTime.Now.Year Labilletterie — Tous droits réservés</p>
    </footer>

    <!-- JavaScript pour le menu burger -->
    <script>
                // Récupère le bouton burger et le menu
                const burger = document.getElementById('burger');
                const menu = document.getElementById('menu');

                // Au clic sur le burger, ouvre/ferme le menu
                burger.addEventListener('click', () => {
                    menu.classList.toggle('navbar__liens--ouvert');
                });
    </script>

</body>

</html>